{
  "name": "costaff-agent-coding",
  "version": "1.0.0",
  "description": "[專長] 程式開發與邏輯運算。[能力] 編寫 Python 程式、處理數據運算、修復 CSV 與資料清洗。[限制] 執行環境僅具備基礎系統字體，產出的 PDF/圖表無法顯示多國語言（如中文），必須將此類視覺化任務交由專業報告專家處理。[產出] 檔案、程式碼或者程式碼運行結果。",
  "a2a_service": "agent-coding",
  "port": 8081,
  "env_required": [
    "GOOGLE_API_KEY"
  ],
  "env_optional": [
    "GIT_TOKEN",
    "GIT_AUTHOR_NAME",
    "GIT_AUTHOR_EMAIL"
  ],
  "env_shared": [
    "GOOGLE_API_KEY",
    "COSTAFF_AGENT_MODEL_PROVIDER",
    "LITELLM_MODEL_NAME",
    "LITELLM_API_BASE",
    "LITELLM_API_KEY"
  ],
  "env_auto": [
    "CODING_AGENT_MCP_URLS"
  ],
  "model_env_var": "CODING_AGENT_MODEL",
  "health_path": "/.well-known/agent-card.json",
  "costaff_sdk_version": ">=0.2.0",
  "mcp_configurable": true,
  "mcp_env_var": "CODING_AGENT_MCP_URLS"
}

