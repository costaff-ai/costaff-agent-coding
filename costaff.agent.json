{
  "name": "coding-agent",
  "version": "1.0.0",
  "description": "寫程式並執行來解決需要計算、資料處理或程式邏輯的問題，回傳執行結果與產生的檔案路徑。",
  "a2a_service": "agent-coding",
  "port": 8081,
  "env_required": [
    "GOOGLE_API_KEY"
  ],
  "env_optional": [
    "GIT_TOKEN",
    "GIT_AUTHOR_NAME",
    "GIT_AUTHOR_EMAIL"
  ],
  "env_shared": [
    "GOOGLE_API_KEY",
    "COSTAFF_AGENT_MODEL_PROVIDER",
    "LITELLM_MODEL_NAME",
    "LITELLM_API_BASE",
    "LITELLM_API_KEY"
  ],
  "env_auto": [
    "CODING_AGENT_MCP_URLS"
  ],
  "model_env_var": "CODING_AGENT_MODEL",
  "health_path": "/.well-known/agent.json",
  "costaff_sdk_version": ">=0.2.0",
  "mcp_configurable": true,
  "mcp_env_var": "CODING_AGENT_MCP_URLS"
}
