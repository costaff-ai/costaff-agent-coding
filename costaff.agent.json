{
  "name": "costaff-agent-coding",
  "version": "1.0.0",
  "description": "專業的程式開發與邏輯專家。負責編寫程式、處理數據運算、修復 CSV 並產出原始數據檔案。限制：執行環境僅支援基礎字體，產出的 PDF 或圖表無法顯示多國語言（如中文），請務必將此類視覺化任務交由專業報告專家處理。",
  "a2a_service": "agent-coding",
  "port": 8081,
  "env_required": [
    "GOOGLE_API_KEY"
  ],
  "env_optional": [
    "GIT_TOKEN",
    "GIT_AUTHOR_NAME",
    "GIT_AUTHOR_EMAIL"
  ],
  "env_shared": [
    "GOOGLE_API_KEY",
    "COSTAFF_AGENT_MODEL_PROVIDER",
    "LITELLM_MODEL_NAME",
    "LITELLM_API_BASE",
    "LITELLM_API_KEY"
  ],
  "env_auto": [
    "CODING_AGENT_MCP_URLS"
  ],
  "model_env_var": "CODING_AGENT_MODEL",
  "health_path": "/.well-known/agent.json",
  "costaff_sdk_version": ">=0.2.0",
  "mcp_configurable": true,
  "mcp_env_var": "CODING_AGENT_MCP_URLS"
}
