# =============================================================================
# CoStaff — Coding Agent Configuration
# =============================================================================
# Instructions:
#   1. Copy this file to .env  →  cp .env.template .env
#   2. Fill in all [REQUIRED] fields
#   3. Pick one option under AI Model
# =============================================================================


# -----------------------------------------------------------------------------
# AI MODEL  [REQUIRED — pick one provider]
# -----------------------------------------------------------------------------

# Active provider: "gemini" or "litellm"
COSTAFF_AGENT_MODEL_PROVIDER=gemini

# -- Option A: Google Gemini (default) ---------------------------------------
# Get API key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Enter any Gemini model name (e.g. gemini-3-flash-preview, gemini-2.5-pro)
CODING_AGENT_MODEL=gemini-3-flash-preview

# -- Option B: LiteLLM -------------------------------------------------------
# Only fill these if COSTAFF_AGENT_MODEL_PROVIDER=litellm
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL_NAME=


# -----------------------------------------------------------------------------
# GIT  [OPTIONAL — for git operations inside the agent]
# -----------------------------------------------------------------------------

GIT_TOKEN=
GIT_AUTHOR_NAME=Coding Agent
GIT_AUTHOR_EMAIL=agent@costaff.ai


# -----------------------------------------------------------------------------
# GENERAL  [OPTIONAL]
# -----------------------------------------------------------------------------

# Allow the agent to install pip packages at runtime (true/false)
ALLOW_PIP_INSTALL=true
